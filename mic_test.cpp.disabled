// Mic diagnostic sketch — rename to main.cpp to use (rename original main.cpp first)
// Prints raw I2S samples to Serial so you can verify the mic is working.

#include <Arduino.h>
#include <driver/i2s.h>

#define SAMPLE_BUFFER_SIZE 512
#define SAMPLE_RATE        8000

#define I2S_MIC_SERIAL_CLOCK  GPIO_NUM_32
#define I2S_MIC_LEFT_RIGHT_CLOCK GPIO_NUM_25
#define I2S_MIC_SERIAL_DATA   GPIO_NUM_33

i2s_config_t i2s_config = {
    .mode = (i2s_mode_t)(I2S_MODE_MASTER | I2S_MODE_RX),
    .sample_rate = SAMPLE_RATE,
    .bits_per_sample = I2S_BITS_PER_SAMPLE_32BIT,
    .channel_format = I2S_CHANNEL_FMT_ONLY_LEFT,
    .communication_format = I2S_COMM_FORMAT_I2S,
    .intr_alloc_flags = ESP_INTR_FLAG_LEVEL1,
    .dma_buf_count = 4,
    .dma_buf_len = 1024,
    .use_apll = false,
    .tx_desc_auto_clear = false,
    .fixed_mclk = 0
};

i2s_pin_config_t i2s_mic_pins = {
    .bck_io_num = I2S_MIC_SERIAL_CLOCK,
    .ws_io_num = I2S_MIC_LEFT_RIGHT_CLOCK,
    .data_out_num = I2S_PIN_NO_CHANGE,
    .data_in_num = I2S_MIC_SERIAL_DATA
};

int32_t raw_samples[SAMPLE_BUFFER_SIZE];

void setup() {
    Serial.begin(115200);
    delay(1000);
    Serial.println("Mic test starting...");
    i2s_driver_install(I2S_NUM_0, &i2s_config, 0, NULL);
    i2s_set_pin(I2S_NUM_0, &i2s_mic_pins);
    delay(500);
    Serial.println("I2S ready. Printing samples...");
}

void loop() {
    size_t bytes_read = 0;
    i2s_read(I2S_NUM_0, raw_samples, sizeof(int32_t) * SAMPLE_BUFFER_SIZE, &bytes_read, portMAX_DELAY);
    int N = bytes_read / sizeof(int32_t);

    Serial.print("bytes_read="); Serial.print(bytes_read);
    Serial.print("  N="); Serial.println(N);

    // Print min, max, and a few samples to check for signal
    int32_t mn = raw_samples[0], mx = raw_samples[0];
    for (int i = 0; i < N; i++) {
        if (raw_samples[i] < mn) mn = raw_samples[i];
        if (raw_samples[i] > mx) mx = raw_samples[i];
    }
    Serial.print("  min="); Serial.print(mn);
    Serial.print("  max="); Serial.print(mx);
    Serial.print("  range="); Serial.println(mx - mn);

    // Print first 8 samples raw and shifted
    Serial.print("  raw:  ");
    for (int i = 0; i < 8; i++) { Serial.print(raw_samples[i]); Serial.print(" "); }
    Serial.println();

    Serial.print("  >>8:  ");
    for (int i = 0; i < 8; i++) { Serial.print(raw_samples[i] >> 8); Serial.print(" "); }
    Serial.println();

    Serial.print("  >>14: ");
    for (int i = 0; i < 8; i++) { Serial.print(raw_samples[i] >> 14); Serial.print(" "); }
    Serial.println();
}
